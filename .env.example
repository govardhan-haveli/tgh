# Supabase Configuration (Public variables for React frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Key (For backend/edge functions - DO NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudinary Configuration (Unsigned upload preset for frontend image upload)
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset

# Cloudinary Private API Credentials
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
